{
  "name": "healthos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "export": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "npm run test:unit",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:regression": "npm run test:unit && npm run test:e2e",
    "infra:cdk:install": "npm --prefix infra/cdk install",
    "infra:cdk:build": "npm --prefix infra/cdk run build",
    "infra:cdk:synth": "npm --prefix infra/cdk run synth",
    "infra:cdk:bootstrap": "npm --prefix infra/cdk run bootstrap",
    "infra:cdk:deploy": "npm --prefix infra/cdk run deploy",
    "stage6:cutover": "node scripts/stage6-validate-cutover.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1014.0",
    "aws-jwt-verify": "^5.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "nanoid": "^5.0.8",
    "next": "^16.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vitest": "^4.1.1"
  }
}
